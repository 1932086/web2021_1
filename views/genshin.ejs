<!Doctype html>
<html>
<head>
<meta charset="utf-8">
<title>Show message</title>
</head>
<body>
  <h2>原神キャラクター一覧</h2>
  <table>
<% for( let row of data ) { %>
    <tr>
<td>ID.</td><td><%= row.id %></td>
<td>　名前.</td><td><a href="/db/<%= row.id %>"><%= row.name %></td>
<td>　性別.</td><td><%= row.gender %></td>
<td>　武器種.</td><td><%= row.weapon %></td>
<td>　元素.</td><td><%= row.element %></td>
    </tr>
  <% } %>

<td><tr><a href='/top'>戻る</a></tr><br>

</table>

</body>

</html>
